@inherits TabComponentWithChildren

@if (Visible)
{
    <NavLink href="@GetHref()" target="@GetTarget()" id="@GetId()" ActiveClass="@ActiveClass" class="@GetCssClass()" Match="@Match">
        @if (ChildContent != null)
        {
            @ChildContent
        }
        else
        {
            @Text
        }
    </NavLink>
}